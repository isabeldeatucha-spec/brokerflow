# Sedge environment variables
# Copy this file to .env and fill in your values.
# Never commit a populated .env to version control.

# Required
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Required when Tavily search is enabled (tools.py: search())
TAVILY_API_KEY=your_tavily_api_key_here

# Required when Gmail sending is enabled (tools.py: send_email())
# Follow the Gmail API quickstart to generate credentials.json
# https://developers.google.com/gmail/api/quickstart/python
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_SENDER_ADDRESS=you@yourdomain.com

# Telegram bot (telegram_bot.py)
# Get token from @BotFather on Telegram
# Get your chat ID by messaging @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# Optional: change digest schedule (24-hour, default 8:00 AM)
DIGEST_HOUR=8
DIGEST_MINUTE=0

PARALLEL_API_KEY=your_parallel_api_key_here

# Firecrawl — for Amazon scraping (https://firecrawl.dev)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Supabase — get from dashboard: Settings → API
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_KEY=your_supabase_anon_key_here
