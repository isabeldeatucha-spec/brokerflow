# Anthropic (required for AI agent)
ANTHROPIC_API_KEY=

# Google Maps (routing + geocoding)
GOOGLE_MAPS_API_KEY=

# Outscraper - alternative Google Maps data (optional, used if GOOGLE_MAPS_API_KEY not set)
OUTSCRAPER_API_KEY=

# Apple Maps Server API
# Get credentials at: https://developer.apple.com/maps/web/
APPLE_MAPS_KEY_ID=
APPLE_TEAM_ID=
APPLE_MAPS_PRIVATE_KEY=   # Full PEM content (replace newlines with \n)

# MBTA API (optional - increases rate limit)
MBTA_API_KEY=

# Microsoft / Outlook calendar
# Register app at: https://portal.azure.com → Azure Active Directory → App registrations
# Permissions needed: Calendars.Read (Application)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
OUTLOOK_USER_EMAIL=you@mit.edu

# Supabase (existing Sedge config - not required for commute planner)
SUPABASE_URL=
SUPABASE_KEY=
